generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                                              Int              @id @default(autoincrement())
  name                                            String
  email                                           String           @unique
  password                                        String
  role                                            Role
  tasks                                           Task[]           @relation("UserTasks")
  TaskCriteria                                    TaskCriteria[]
  TaskSubmission_TaskSubmission_createdByIdToUser TaskSubmission[] @relation("TaskSubmission_createdByIdToUser")
  submissions                                     TaskSubmission[]
}

model Task {
  id                  Int                   @id @default(autoincrement())
  title               String
  description         String
  code                String                @unique
  createdAt           DateTime              @default(now())
  deadline            DateTime
  createdById         Int
  ParameterSubmission ParameterSubmission[]
  createdBy           User                  @relation("UserTasks", fields: [createdById], references: [id])
  criteria            TaskCriteria[]
  submissions         TaskSubmission[]
}

model TaskCriteria {
  id          Int      @id @default(autoincrement())
  title       String
  weight      Float
  description String
  createdAt   DateTime @default(now())
  createdById Int
  taskId      Int
  User        User     @relation(fields: [createdById], references: [id])
  task        Task     @relation(fields: [taskId], references: [id])
}

model TaskSubmission {
  id                                    Int      @id @default(autoincrement())
  fileUrl                               String
  createdAt                             DateTime @default(now())
  aiFeedback                            String?
  aiGrade                               Float?
  createdById                           Int
  userId                                Int
  taskId                                Int
  User_TaskSubmission_createdByIdToUser User     @relation("TaskSubmission_createdByIdToUser", fields: [createdById], references: [id])
  task                                  Task     @relation(fields: [taskId], references: [id])
  user                                  User     @relation(fields: [userId], references: [id])
}

model ParameterSubmission {
  id          Int      @id @default(autoincrement())
  title       String
  weight      Float
  description String
  createdAt   DateTime @default(now())
  taskId      Int
  Task        Task     @relation(fields: [taskId], references: [id])
}

enum Role {
  PROFESSOR
  ALUNO
}
